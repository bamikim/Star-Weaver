[gd_scene load_steps=2 format=3]

[ext_resource path="res://scripts/ui/SpiritsTab.gd" type="Script" id=1]

[node name="SpiritsTab" type="Control"]
script = ExtResource( 1 )

[node name="Background" type="ColorRect" parent="."]
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.15, 0.1, 0.2, 1)

[node name="VBoxContainer" type="VBoxContainer" parent="."]
anchor_right = 1.0
anchor_bottom = 1.0
custom_constants/separation = 20
alignment = 1

[node name="TitleLabel" type="Label" parent="VBoxContainer"]
text = "정령 시스템"
align = 1
custom_fonts/font = SubResource("Font_1")

[node name="InfoLabel" type="Label" parent="VBoxContainer"]
